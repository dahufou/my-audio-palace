# --- Aurum Server config ---
NODE_ENV=production
HOST=127.0.0.1
PORT=4477

# Bibliothèque musicale (chemin absolu sur le LXC)
MUSIC_PATH=/mnt/music

# PostgreSQL
DATABASE_URL=postgres://aurum:CHANGE_ME@127.0.0.1:5432/aurum

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# Token "bridge" pour les endpoints internes (Chromecast/UPnP) — généré par install.sh
BRIDGE_TOKEN=CHANGE_ME

# Transcodage
FFMPEG_PATH=/usr/bin/ffmpeg
TRANSCODE_CACHE=/var/cache/aurum/transcode

# Logs
LOG_LEVEL=info

# --- Sources d'images externes (toutes optionnelles) ---
# Spotify : https://developer.spotify.com/dashboard → "Create app" → Client Credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Last.fm : https://www.last.fm/api/account/create
LASTFM_API_KEY=
