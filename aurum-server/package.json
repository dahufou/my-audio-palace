{
  "name": "aurum-server",
  "version": "0.1.0",
  "private": true,
  "description": "Roon-like audio server for Debian (Aurum)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
